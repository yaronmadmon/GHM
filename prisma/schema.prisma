generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ORGANIZATIONS (multi-tenancy root)
// ─────────────────────────────────────────
model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  properties          Property[]
  tenants             Tenant[]
  leases              Lease[]
  rentPayments        RentPayment[]
  maintenanceRequests MaintenanceRequest[]
  vendors             Vendor[]
  transactions        Transaction[]
  activityEvents      ActivityEvent[]
  lateFeeConfig       LateFeeConfig?
  applicationInvites  ApplicationInvite[]
  applications        Application[]
  messages            Message[]
  paymentRequests     PaymentRequest[]

  @@map("organizations")
}

// ─────────────────────────────────────────
// USERS
// ─────────────────────────────────────────
model User {
  id             String  @id @default(cuid())
  organizationId String
  email          String  @unique
  passwordHash   String?
  name           String?
  role           String  @default("owner") // owner | member | viewer | tenant
  avatarUrl      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization         Organization         @relation(fields: [organizationId], references: [id])
  leaseDocuments       LeaseDocument[]
  recordedPayments     RentPayment[]
  activityEvents       ActivityEvent[]
  maintenanceComments  MaintenanceComment[]
  reviewedApplications Application[]        @relation("reviewer")
  applicationInvites   ApplicationInvite[]

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────
// PROPERTIES
// ─────────────────────────────────────────
model Property {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  addressLine1   String
  addressLine2   String?
  city           String
  state          String
  zip            String
  country        String    @default("US")
  propertyType   String    @default("single_family") // single_family | multi_unit | condo | commercial
  unitCount      Int       @default(1)
  status         String    @default("vacant") // occupied | vacant | under_maintenance
  description    String?
  purchasePrice  Decimal?  @db.Decimal(12, 2)
  purchaseDate   DateTime?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id])
  photos              PropertyPhoto[]
  units               Unit[]
  maintenanceRequests MaintenanceRequest[]
  transactions        Transaction[]
  applicationInvites  ApplicationInvite[]
  applications        Application[]

  @@index([organizationId])
  @@index([status])
  @@map("properties")
}

model PropertyPhoto {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  caption    String?
  isCover    Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_photos")
}

// ─────────────────────────────────────────
// UNITS
// ─────────────────────────────────────────
model Unit {
  id         String   @id @default(cuid())
  propertyId String
  unitNumber String
  bedrooms   Decimal? @db.Decimal(3, 1)
  bathrooms  Decimal? @db.Decimal(3, 1)
  sqft       Int?
  status     String   @default("vacant") // occupied | vacant | under_maintenance
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property            Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases              Lease[]
  maintenanceRequests MaintenanceRequest[]
  transactions        Transaction[]
  applicationInvites  ApplicationInvite[]
  applications        Application[]

  @@unique([propertyId, unitNumber])
  @@index([propertyId])
  @@index([status])
  @@map("units")
}

// ─────────────────────────────────────────
// TENANTS
// ─────────────────────────────────────────
model Tenant {
  id                    String    @id @default(cuid())
  organizationId        String
  firstName             String
  lastName              String
  email                 String?
  phone                 String?
  dateOfBirth           DateTime?
  ssnLast4              String?
  idType                String? // drivers_license | passport | state_id
  idNumber              String?
  emergencyContactName  String?
  emergencyContactPhone String?
  notes                 String?
  portalUserId          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  organization       Organization         @relation(fields: [organizationId], references: [id])
  leaseLinks         LeaseTenant[]
  maintenanceReports MaintenanceRequest[]
  convertedFrom      Application?         @relation("converted_tenant")

  @@index([organizationId])
  @@index([email])
  @@index([lastName])
  @@map("tenants")
}

// ─────────────────────────────────────────
// LEASES
// ─────────────────────────────────────────
model Lease {
  id              String    @id @default(cuid())
  organizationId  String
  unitId          String
  startDate       DateTime
  endDate         DateTime?
  rentAmount      Decimal   @db.Decimal(10, 2)
  depositAmount   Decimal?  @db.Decimal(10, 2)
  depositPaid     Boolean   @default(false)
  depositPaidAt   DateTime?
  status          String    @default("active") // active | expired | terminated | pending
  leaseType       String    @default("fixed") // fixed | month_to_month
  lateFeeAmount   Decimal?  @db.Decimal(10, 2)
  lateFeGraceDays Int       @default(5)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization  Organization    @relation(fields: [organizationId], references: [id])
  unit          Unit            @relation(fields: [unitId], references: [id])
  tenants       LeaseTenant[]
  documents     LeaseDocument[]
  rentPayments  RentPayment[]
  transactions  Transaction[]
  convertedFrom Application?    @relation("converted_lease")

  @@index([organizationId])
  @@index([unitId])
  @@index([status])
  @@index([endDate])
  @@map("leases")
}

model LeaseTenant {
  id        String   @id @default(cuid())
  leaseId   String
  tenantId  String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  lease  Lease  @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([leaseId, tenantId])
  @@index([tenantId])
  @@map("lease_tenants")
}

model LeaseDocument {
  id            String   @id @default(cuid())
  leaseId       String
  name          String
  url           String
  fileType      String? // pdf | docx | image
  fileSizeBytes Int?
  uploadedById  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lease      Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation(fields: [uploadedById], references: [id])

  @@index([leaseId])
  @@map("lease_documents")
}

// ─────────────────────────────────────────
// RENT PAYMENTS
// ─────────────────────────────────────────
model RentPayment {
  id             String    @id @default(cuid())
  organizationId String
  leaseId        String
  periodYear     Int
  periodMonth    Int // 1-12
  amountDue      Decimal   @db.Decimal(10, 2)
  amountPaid     Decimal   @default(0) @db.Decimal(10, 2)
  status         String    @default("pending") // paid | partial | overdue | pending
  dueDate        DateTime
  paidAt         DateTime?
  paymentMethod  String? // cash | check | ach | zelle | venmo | other
  lateFeeApplied Decimal?  @db.Decimal(10, 2)
  notes          String?
  recordedById   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  lease        Lease        @relation(fields: [leaseId], references: [id])
  recordedBy   User?        @relation(fields: [recordedById], references: [id])

  @@unique([leaseId, periodYear, periodMonth])
  @@index([organizationId])
  @@index([leaseId])
  @@index([status])
  @@index([dueDate])
  @@map("rent_payments")
}

// ─────────────────────────────────────────
// MAINTENANCE
// ─────────────────────────────────────────
model MaintenanceRequest {
  id                 String    @id @default(cuid())
  organizationId     String
  propertyId         String
  unitId             String?
  title              String
  description        String
  priority           String    @default("medium") // low | medium | high | emergency
  status             String    @default("open") // open | in_progress | pending_parts | completed | cancelled
  category           String? // plumbing | electrical | hvac | appliance | structural | other
  reportedByTenantId String?
  assignedVendorId   String?
  resolvedAt         DateTime?
  estimatedCost      Decimal?  @db.Decimal(10, 2)
  actualCost         Decimal?  @db.Decimal(10, 2)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization     Organization         @relation(fields: [organizationId], references: [id])
  property         Property             @relation(fields: [propertyId], references: [id])
  unit             Unit?                @relation(fields: [unitId], references: [id])
  reportedByTenant Tenant?              @relation(fields: [reportedByTenantId], references: [id])
  assignedVendor   Vendor?              @relation(fields: [assignedVendorId], references: [id])
  comments         MaintenanceComment[]
  photos           MaintenancePhoto[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([status])
  @@index([priority])
  @@map("maintenance_requests")
}

model MaintenanceComment {
  id        String   @id @default(cuid())
  requestId String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  request MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author  User               @relation(fields: [authorId], references: [id])

  @@index([requestId])
  @@map("maintenance_comments")
}

model MaintenancePhoto {
  id        String   @id @default(cuid())
  requestId String
  url       String
  createdAt DateTime @default(now())

  request MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("maintenance_photos")
}

// ─────────────────────────────────────────
// VENDORS
// ─────────────────────────────────────────
model Vendor {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  trade          String? // plumber | electrician | general | hvac
  email          String?
  phone          String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id])
  maintenanceRequests MaintenanceRequest[]

  @@index([organizationId])
  @@map("vendors")
}

// ─────────────────────────────────────────
// FINANCIALS
// ─────────────────────────────────────────
model Transaction {
  id             String   @id @default(cuid())
  organizationId String
  propertyId     String?
  unitId         String?
  leaseId        String?
  type           String // income | expense
  category       String // rent | late_fee | deposit | repair | insurance | tax | utility | management | other
  amount         Decimal  @db.Decimal(10, 2)
  date           DateTime
  description    String?
  paymentMethod  String?
  referenceId    String?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property?    @relation(fields: [propertyId], references: [id])
  unit         Unit?        @relation(fields: [unitId], references: [id])
  lease        Lease?       @relation(fields: [leaseId], references: [id])

  @@index([organizationId])
  @@index([propertyId])
  @@index([date])
  @@index([type, category])
  @@map("transactions")
}

// ─────────────────────────────────────────
// ACTIVITY FEED
// ─────────────────────────────────────────
model ActivityEvent {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String?
  entityType     String // property | tenant | lease | payment | maintenance | application
  entityId       String
  eventType      String // created | updated | status_changed | payment_recorded
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  actor        User?        @relation(fields: [actorId], references: [id])

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("activity_events")
}

// ─────────────────────────────────────────
// LATE FEE CONFIG
// ─────────────────────────────────────────
model LateFeeConfig {
  id              String   @id @default(cuid())
  organizationId  String   @unique
  gracePeriodDays Int      @default(5)
  feeType         String   @default("flat") // flat | percentage
  flatAmount      Decimal? @db.Decimal(10, 2)
  percentage      Decimal? @db.Decimal(5, 2)
  maxFeeAmount    Decimal? @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("late_fee_configs")
}

// ─────────────────────────────────────────
// APPLICATIONS MODULE
// ─────────────────────────────────────────
model ApplicationInvite {
  id             String    @id @default(cuid())
  organizationId String
  propertyId     String
  unitId         String?
  token          String    @unique
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  property     Property      @relation(fields: [propertyId], references: [id])
  unit         Unit?         @relation(fields: [unitId], references: [id])
  createdBy    User?         @relation(fields: [createdById], references: [id])
  applications Application[]

  @@index([token])
  @@index([organizationId])
  @@map("application_invites")
}

model Application {
  id             String   @id @default(cuid())
  organizationId String
  inviteId       String?
  propertyId     String
  unitId         String?
  status         String   @default("pending") // pending | approved | denied

  // Personal info
  firstName   String
  lastName    String
  email       String
  phone       String?
  dateOfBirth DateTime?

  // Employment
  employerName        String?
  employerPhone       String?
  jobTitle            String?
  employmentStartDate DateTime?
  monthlyIncome       Decimal?  @db.Decimal(10, 2)
  incomeVerified      Boolean   @default(false)

  // Rental history
  currentAddress       String?
  currentLandlordName  String?
  currentLandlordPhone String?
  previousAddress      String?
  reasonForMoving      String?

  // Pets / vehicles
  hasPets             Boolean @default(false)
  petsDescription     String?
  hasVehicles         Boolean @default(false)
  vehiclesDescription String?

  // Background check
  backgroundCheckStatus String?
  backgroundCheckNotes  String?
  backgroundCheckDate   DateTime?

  // Signature
  signatureData String?
  signedAt      DateTime?
  ipAddress     String?

  // Decision
  reviewedById  String?
  reviewedAt    DateTime?
  decisionNotes String?

  // Resulting records on approval
  convertedTenantId String? @unique
  convertedLeaseId  String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization          @relation(fields: [organizationId], references: [id])
  invite          ApplicationInvite?    @relation(fields: [inviteId], references: [id])
  property        Property              @relation(fields: [propertyId], references: [id])
  unit            Unit?                 @relation(fields: [unitId], references: [id])
  reviewedBy      User?                 @relation("reviewer", fields: [reviewedById], references: [id])
  convertedTenant Tenant?               @relation("converted_tenant", fields: [convertedTenantId], references: [id])
  convertedLease  Lease?                @relation("converted_lease", fields: [convertedLeaseId], references: [id])
  references      ApplicationReference[]
  documents       ApplicationDocument[]

  @@index([organizationId])
  @@index([status])
  @@index([propertyId])
  @@index([email])
  @@map("applications")
}

model ApplicationReference {
  id            String   @id @default(cuid())
  applicationId String
  type          String // landlord | employer | personal
  name          String
  relationship  String?
  phone         String?
  email         String?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_references")
}

model ApplicationDocument {
  id            String   @id @default(cuid())
  applicationId String
  name          String
  url           String
  docType       String? // pay_stub | id | bank_statement | other
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_documents")
}

// ─────────────────────────────────────────
// MESSAGES (landlord <-> tenant communication)
// ─────────────────────────────────────────
model Message {
  id             String   @id @default(cuid())
  organizationId String
  threadId       String
  senderId       String // userId
  senderRole     String // landlord | tenant
  recipientId    String // userId of recipient
  subject        String?
  body           String
  isRead         Boolean  @default(false)
  attachmentUrl  String?
  relatedType    String? // lease | maintenance | payment
  relatedId      String?
  createdAt      DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id])
  thread       MessageThread @relation(fields: [threadId], references: [id])

  @@index([organizationId])
  @@index([threadId])
  @@index([recipientId, isRead])
  @@map("messages")
}

model MessageThread {
  id             String   @id @default(cuid())
  organizationId String
  subject        String
  landlordUserId String
  tenantUserId   String
  leaseId        String?
  lastMessageAt  DateTime @default(now())
  createdAt      DateTime @default(now())

  messages Message[]

  @@index([organizationId])
  @@index([tenantUserId])
  @@index([landlordUserId])
  @@map("message_threads")
}

// ─────────────────────────────────────────
// PAYMENT REQUESTS (tenant-initiated)
// ─────────────────────────────────────────
model PaymentRequest {
  id             String   @id @default(cuid())
  organizationId String
  leaseId        String
  tenantUserId   String
  amount         Decimal  @db.Decimal(10, 2)
  method         String // cash | check | ach | zelle | venmo | other
  notes          String?
  receiptUrl     String?
  status         String   @default("pending") // pending | confirmed | rejected
  periodYear     Int
  periodMonth    Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([leaseId])
  @@index([status])
  @@map("payment_requests")
}

// ─────────────────────────────────────────
// TENANT NOTIFICATIONS
// ─────────────────────────────────────────
model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       String // message | payment_due | maintenance_update | lease_expiry
  title      String
  body       String
  isRead     Boolean  @default(false)
  relatedUrl String?
  createdAt  DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}
